# =============================================================================
# Environment Configuration Template
# Copy this file to .env and fill in your values
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/property_bot
DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/property_bot

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_REGULAR=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o

# Application
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Security
SECRET_KEY=your-secret-key-generate-a-random-one
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Query Limits
MAX_QUERY_RESULTS=100
MAX_FILTERS_PER_QUERY=10
